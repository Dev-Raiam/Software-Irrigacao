{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "ConnectionStrings": {
    "LocalDatabase": "Data Source=database.db"
  },
  "ApiConfiguration": {
    "BaseUrl": "https://api.toolbox.app.br",
    "TimeoutSeconds": 30,
    "RetryAttempts": 3,
    "RetryDelaySeconds": 2
  },
  "MqttConfiguracao": {
    "BrokerLocal": "localhost",
    "BrokerRemoto": "broker.freemqtt.com",
    "Porta": 1883,
    "UsuarioRemoto": "freemqtt",
    "SenhaRemoto": "public"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:4900"
      }
    }
  }
}
