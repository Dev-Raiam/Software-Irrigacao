{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "ConnectionStrings": {
    "LocalDatabase": "Data Source=database.db"
  },
  "ApiConfiguration": {
    "BaseUrl": "https://api.toolbox.app.br",
    "TimeoutSeconds": 30,
    "RetryAttempts": 3,
    "RetryDelaySeconds": 2
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:4900"
      }
    }
  }
}
